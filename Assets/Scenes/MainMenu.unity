  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 19
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 10
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 0
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 1
    m_LineSpacing: 1
  m_Text: "Tr\xF2 ch\u01A1i \u0111\u01B0a b\u1EA1n \u0111i qua c\xE1c giai \u0111o\u1EA1n
    l\u1ECBch s\u1EED Vi\u1EC7t Nam qua t\u1EEBng b\u1EA3n \u0111\u1ED3 \u2014 t\u1EEB
    nh\u1EEFng n\u0103m kh\xE1ng chi\u1EBFn \u0111\u1EBFn th\u1EDDi k\u1EF3 \u0111\u1ED5i
    m\u1EDBi. B\u1EA1n s\u1EBD nh\u1EADp vai nh\xE2n v\u1EADt, ho\xE0n th\xE0nh nhi\u1EC7m
    v\u1EE5 v\xE0 kh\xE1m ph\xE1 s\u1EF1 ki\u1EC7n \u0111\u01B0\u1EE3c g\u1EE3i nh\u1EDB
    qua b\u1ED1i c\u1EA3nh, \u0111\u1ED1i tho\u1EA1i v\xE0 m\xF4i tr\u01B0\u1EDDng.\n\nM\u1EE5c
    ti\xEAu l\xE0 v\u1EEBa ch\u01A1i v\u1EEBa n\u1EAFm \u0111\u01B0\u1EE3c d\xF2ng
    th\u1EDDi gian v\xE0 \xFD ngh\u0129a c\u1EE7a t\u1EEBng m\u1ED1c s\u1EED, ph\xF9
    h\u1EE3p v\u1EDBi n\u1ED9i dung m\xF4n h\u1ECDc / \u0111\u1ED3 \xE1n c\u1EE7a
    nh\xF3m."
