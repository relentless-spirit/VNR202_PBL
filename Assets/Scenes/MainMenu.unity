MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 800000001}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7a8b9c0d1e2f3456789012345678abcd, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  backdropBase: {r: 0.11, g: 0.08, b: 0.06, a: 1}
  parchmentWash: {r: 0.72, g: 0.58, b: 0.38, a: 0.09}
  vignetteTop: {r: 0.42, g: 0.28, b: 0.14, a: 0.28}
  vignetteBottom: {r: 0.05, g: 0.02, b: 0.02, a: 0.62}
  centerGlow: {r: 0.75, g: 0.55, b: 0.28, a: 0.07}
  accentStripe: {r: 0.72, g: 0.55, b: 0.22, a: 0.92}
  accentStripeInner: {r: 0.2, g: 0.12, b: 0.08, a: 0.85}
  cardTint: {r: 0.22, g: 0.17, b: 0.12, a: 0.78}
  cardBorder: {r: 0.55, g: 0.4, b: 0.22, a: 0.55}
  primaryButton: {r: 0.48, g: 0.14, b: 0.14, a: 1}
  primaryButtonHover: {r: 0.62, g: 0.2, b: 0.18, a: 1}
  secondaryButton: {r: 0.94, g: 0.88, b: 0.78, a: 0.32}
  secondaryButtonHover: {r: 0.96, g: 0.9, b: 0.8, a: 0.45}
  helpStoryText: "Tr\xF2 ch\u01A1i \u0111\u01B0a b\u1EA1n \u0111i qua c\xE1c giai
    \u0111o\u1EA1n l\u1ECBch s\u1EED Vi\u1EC7t Nam qua t\u1EEBng b\u1EA3n \u0111\u1ED3
    \u2014 t\u1EEB nh\u1EEFng n\u0103m kh\xE1ng chi\u1EBFn \u0111\u1EBFn th\u1EDDi
    k\u1EF3 \u0111\u1ED5i m\u1EDBi. B\u1EA1n s\u1EBD nh\u1EADp vai nh\xE2n v\u1EADt,
    ho\xE0n th\xE0nh nhi\u1EC7m v\u1EE5 v\xE0 kh\xE1m ph\xE1 s\u1EF1 ki\u1EC7n \u0111\u01B0\u1EE3c
    g\u1EE3i nh\u1EDB qua b\u1ED1i c\u1EA3nh, \u0111\u1ED1i tho\u1EA1i v\xE0 m\xF4i
    tr\u01B0\u1EDDng.\n\nM\u1EE5c ti\xEAu l\xE0 v\u1EEBa ch\u01A1i v\u1EEBa n\u1EAFm
    \u0111\u01B0\u1EE3c d\xF2ng th\u1EDDi gian v\xE0 \xFD ngh\u0129a c\u1EE7a t\u1EEBng
    m\u1ED1c s\u1EED, ph\xF9 h\u1EE3p v\u1EDBi n\u1ED9i dung m\xF4n h\u1ECDc / \u0111\u1ED3
    \xE1n c\u1EE7a nh\xF3m."
  helpHowToText: "\U0001F3AE **H\u01AF\u1EDANG D\u1EAAN CH\u01A0I**\r\n\r\n---\r\n\r\n\U0001F579\uFE0F
    **\u0110i\u1EC1u khi\u1EC3n**\r\n\r\n* Di chuy\u1EC3n b\u1EB1ng **WASD** ho\u1EB7c
    **ph\xEDm m\u0169i t\xEAn**\r\n* Nh\xE2n v\u1EADt s\u1EBD quay theo h\u01B0\u1EDBng
    b\u1EA1n di chuy\u1EC3n\r\n\r\n---\r\n\r\n\U0001F91D **T\u01B0\u01A1ng t\xE1c**\r\n\r\n*
    \u0110\u1EBFn g\u1EA7n **NPC / v\u1EADt th\u1EC3 / \u0111i\u1EC3m nhi\u1EC7m
    v\u1EE5**\r\n* Nh\u1EA5n ph\xEDm t\u01B0\u01A1ng t\xE1c (v\xED d\u1EE5: **Q**
    l\xE0 \u0111\u1EC3 m\u1EDF h\u1ED9i tho\u1EA1i tr\u1EA3 l\u1EDDi c\xE2u h\u1ECFi
    \u0111\u1EC3 nh\u1EADn v\u1EADt ph\u1EA9m, v\xE0 **E** l\xE0 \u0111\u1EC3 giao
    ti\u1EBFp v\u1EDBi m\u1ECDi NPC c\xF3 trong tr\xF2 ch\u01A1i)\r\n\r\n---\r\n\r\n\U0001F4DC
    **Nhi\u1EC7m v\u1EE5**\r\n\r\n* N\xF3i chuy\u1EC7n v\u1EDBi **Tr\u01B0\u1EDFng
    l\xE0ng** \u0111\u1EC3 nh\u1EADn nhi\u1EC7m v\u1EE5\r\n* Ho\xE0n th\xE0nh c\xE1c
    y\xEAu c\u1EA7u nh\u01B0:\r\n\r\n  * Tr\u1EA3 l\u1EDDi c\xE2u h\u1ECFi\r\n  *
    Thu th\u1EADp v\u1EADt ph\u1EA9m (truy\u1EC1n \u0111\u01A1n, bao g\u1EA1o,...)\r\n*
    Mang v\u1EADt ph\u1EA9m \u0111\u1EBFn \u0111\xFAng n\u01A1i \u0111\u1EC3 ho\xE0n
    th\xE0nh nhi\u1EC7m v\u1EE5\r\n\r\n---\r\n\r\n\u26A0\uFE0F **C\u1EA9n th\u1EADn**\r\n\r\n*
    Tr\xE1nh b\u1ECB l\xEDnh ph\xE1t hi\u1EC7n trong l\xFAc l\xE0m nhi\u1EC7m v\u1EE5\r\n*
    N\u1EBFu b\u1ECB b\u1EAFt:\r\n\r\n  * B\u1EA1n s\u1EBD b\u1ECB \u0111\u01B0a
    v\u1EC1 \u0111i\u1EC3m xu\u1EA5t ph m\u1EA5t\r\n\r\n---\r\n\r\n\U0001F9E9 **Mini-game
    (Map cu\u1ED1i)**\r\n\r\n* Nh\u1EA5n v\xE0o c\xE1c \xF4 \u0111\u1EC3 di chuy\u1EC3n\r\n*
    Ch\u1EC9 c\xE1c \xF4 c\u1EA1nh kho\u1EA3ng tr\u1ED1ng m\u1EDBi di chuy\u1EC3n
    \u0111\u01B0\u1EE3c\r\n* S\u1EAFp x\u1EBFp \u0111\xFAng to\xE0n b\u1ED9 h\xECnh
    \u0111\u1EC3 chi\u1EBFn th\u1EAFng\r\n\r\n---\r\n\r\n\U0001F4BE **L\u01B0u game**\r\n\r\n*
    T\xF9y c\u1EA5u h\xECnh: game c\xF3 th\u1EC3 l\u01B0u t\u1EF1 \u0111\u1ED9ng
    ho\u1EB7c theo checkpoint\r\n\r\n---\r\n\r\n\U0001F3C1 **Menu ch\xEDnh**\r\n\r\n*
    **Ch\u01A1i**: B\u1EAFt \u0111\u1EA7u game\r\n* **Tho\xE1t**: \u0110\xF3ng game\r\n\r\n---\r\n\r\n\U0001F525
    Ch\xFAc b\u1EA1n ho\xE0n th\xE0nh nhi\u1EC7m v\u1EE5 v\xE0 gi\xE0nh chi\u1EBFn
    th\u1EAFng!\r\n"
